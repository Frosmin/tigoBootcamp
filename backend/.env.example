
PORT=3050
# ------------------URL---------------------------------------------------
API_BASE_PATH=/api/v1

# ------------------POSTGRES-----------------------------------------------
# Usadas por la libreria @tigo/postgres-connector.
# Opcion 1: variables individuales
P_DB_HOST=localhost
P_DB_PORT=5432
P_DB_NAME=mydatabase
P_DB_USER=postgres
P_DB_PASSWORD=postgres123
P_DB_MAX_CONNECTIONS=10
# Opcion 2 (tiene prioridad si esta definida):
# P_DB_CONNECTION_STRING=postgresql://postgres:postgres123@localhost:5432/mydatabase

# ------------------REDIS---------------------------------------------------
# Usadas directamente por ioredis para la cola y la coordinación del worker.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
NOTIFICATION_STREAM=notifications:dispatch
NOTIFICATION_DELAYED_SET=notifications:delayed
NOTIFICATION_CONSUMER_GROUP=notification-workers
# NOTIFICATION_CONSUMER_NAME=worker-local-1
WORKER_BLOCK_MS=5000
WORKER_CLAIM_IDLE_MS=30000
WORKER_LOCK_TTL_MS=180000
DELIVERED_MARK_TTL_MS=604800000
DELAYED_PROMOTION_INTERVAL_MS=1000

# ------------------REINTENTOS Y THROUGHPUT-------------------------------
MAX_DELIVERY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=30000
RETRY_MAX_DELAY_MS=300000
EMAIL_MAX_PER_MINUTE=60
SMS_MAX_PER_MINUTE=60

# ------------------GMAIL SMTP---------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_CONNECTION_TIMEOUT_MS=30000
SMTP_GREETING_TIMEOUT_MS=30000
SMTP_SOCKET_TIMEOUT_MS=60000
SMTP_USER=tu-cuenta@gmail.com
SMTP_APP_PASSWORD=tu-app-password-de-16-caracteres
SMTP_FROM=tu-cuenta@gmail.com
SMTP_MESSAGE_ID_DOMAIN=gmail.com

