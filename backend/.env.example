PORT=3050
API_BASE_PATH=/api/v1

# PostgreSQL - @tigo/postgres-connector
P_DB_HOST=localhost
P_DB_PORT=5432
P_DB_NAME=mydatabase
P_DB_USER=postgres
P_DB_PASSWORD=postgres123
P_DB_MAX_CONNECTIONS=20
# P_DB_CONNECTION_STRING=postgresql://postgres:postgres123@localhost:5432/mydatabase

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
BULLMQ_PREFIX=p07
EMAIL_QUEUE_NAME=notifications-email
SMS_QUEUE_NAME=notifications-sms

# Entrega y reintentos
WORKER_CHANNEL=EMAIL
WORKER_HEALTH_PORT=3051
DELIVERY_PROVIDER=smtp
DELIVERY_MAX_ATTEMPTS=5
DELIVERY_AUTO_ATTEMPTS=3
DELIVERY_BACKOFF_MS=1000
DELIVERY_BACKOFF_JITTER=0.5
DELIVERY_LEASE_MS=60000
EMAIL_ENABLED=true
SMS_ENABLED=false
EMAIL_RATE_LIMIT_PER_MINUTE=60
EMAIL_WORKER_CONCURRENCY=5
SMS_RATE_LIMIT_PER_MINUTE=60
SMS_WORKER_CONCURRENCY=5

# Transactional outbox
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_MS=250
OUTBOX_LEASE_MS=30000

# Retencion BullMQ
JOBS_COMPLETED_AGE_SECONDS=3600
JOBS_COMPLETED_COUNT=1000
JOBS_FAILED_AGE_SECONDS=604800
JOBS_FAILED_COUNT=5000

# Gmail SMTP. Usar secretos del entorno/Jenkins, nunca versionarlos.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notifications@example.com
SMTP_PASSWORD=replace-with-secret
SMTP_FROM=Notificaciones <notifications@example.com>
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=30000
