
PORT=3050
# ------------------URL---------------------------------------------------
API_BASE_PATH=/api/v1

# ------------------POSTGRES-----------------------------------------------
# Usadas por la libreria @tigo/postgres-connector.
# Opcion 1: variables individuales
P_DB_HOST=localhost
P_DB_PORT=5432
P_DB_NAME=mydatabase
P_DB_USER=postgres
P_DB_PASSWORD=postgres123
P_DB_MAX_CONNECTIONS=10
# Opcion 2 (tiene prioridad si esta definida):
# P_DB_CONNECTION_STRING=postgresql://postgres:postgres123@localhost:5432/mydatabase

# ------------------REDIS / BULLMQ------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
NOTIFICATION_QUEUE=notification-delivery

# ------------------WORKER / OUTBOX-----------------------------------------
MAX_NOTIFICATION_ATTEMPTS=5
RETRY_BACKOFF_MS=1000
SENDS_PER_MINUTE=60
WORKER_CONCURRENCY=5
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_BACKOFF_MS=60000
PROVIDER_TIMEOUT_MS=10000

# ------------------GMAIL SMTP----------------------------------------------
# Usar una App Password, nunca la contrasena normal de la cuenta.
SMTP_USER=notifications.example@gmail.com
SMTP_APP_PASSWORD=replace-with-google-app-password
SMTP_FROM="Notifications <notifications.example@gmail.com>"

# ------------------TWILIO SMS----------------------------------------------
# Credenciales reales: obtenerlas desde https://console.twilio.com/.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_FROM_NUMBER=+15005550006
# Predeterminado: https://api.twilio.com. Cambiar solo para el mock local.
# TWILIO_API_BASE_URL=http://localhost:4010
# Destinatario exclusivo para `npm run test:twilio`; en trial debe estar verificado.
TWILIO_TEST_TO=+59170000000

