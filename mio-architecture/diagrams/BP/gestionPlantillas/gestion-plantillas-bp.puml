@startuml

title Proceso de Negocio (BPMN) - Gestión de Plantillas

skinparam backgroundColor white
skinparam shadowing false
skinparam activity {
    BackgroundColor white
    BorderColor #1676D2
    FontColor #000000
    DiamondBackgroundColor #FFF2CC
    DiamondBorderColor #C99A00
    StartColor #222222
    EndColor #222222
    BarColor #1676D2
}

skinparam swimlane {
    BorderColor #8AB4E8
    TitleBackgroundColor #E8F1FB
    TitleFontColor #003B70
}

|Servicio interno autorizado|

start

:Seleccionar operación sobre plantilla;

note right
Operaciones:
- Crear
- Actualizar
- Eliminar
end note

if (¿Operación solicitada?) then (Crear)

    :Enviar datos de nueva plantilla\nPOST /api/v1/templates;

    note right
    Datos:
    - nombre
    - canal
    - contenido
    - variables[]
    end note

    |API de Plantillas|

    :Validar autenticación\ny autorización;

    if (¿Usuario autorizado?) then (Sí)

        :Validar nombre, canal,\ncontenido y variables;

        if (¿Datos válidos?) then (Sí)

            :Buscar plantilla con el mismo\nnombre y canal;

            if (¿Nombre único por canal?) then (Sí)

                :Crear plantilla;

                :Guardar plantilla\nen base de datos;

                |Servicio interno autorizado|

                :Recibir plantilla creada\nHTTP 201;

                stop

            else (No)

                :Rechazar creación por duplicado;

                |Servicio interno autorizado|

                :Recibir error TEMPLATE_ALREADY_EXISTS\nHTTP 409;

                stop

            endif

        else (No)

            :Rechazar datos inválidos;

            |Servicio interno autorizado|

            :Recibir error de validación\nHTTP 400;

            stop

        endif

    else (No)

        :Rechazar operación no autorizada;

        |Servicio interno autorizado|

        :Recibir error HTTP 401 o 403;

        stop

    endif


elseif (¿Operación solicitada?) then (Actualizar)

    :Enviar actualización\nPUT /api/v1/templates/{id};

    |API de Plantillas|

    :Validar autenticación\ny autorización;

    if (¿Usuario autorizado?) then (Sí)

        :Buscar plantilla por id;

        if (¿Plantilla existente?) then (Sí)

            :Validar nuevos datos;

            if (¿Datos válidos?) then (Sí)

                :Comprobar nombre único\npara el canal;

                if (¿Existe otra plantilla\ncon ese nombre y canal?) then (Sí)

                    :Rechazar actualización\npor nombre duplicado;

                    |Servicio interno autorizado|

                    :Recibir error HTTP 409;

                    stop

                else (No)

                    :Actualizar plantilla;

                    :Guardar cambios\nen base de datos;

                    |Servicio interno autorizado|

                    :Recibir plantilla actualizada\nHTTP 200;

                    stop

                endif

            else (No)

                :Rechazar datos inválidos;

                |Servicio interno autorizado|

                :Recibir error de validación\nHTTP 400;

                stop

            endif

        else (No)

            :Rechazar actualización por\nplantilla inexistente;

            |Servicio interno autorizado|

            :Recibir error HTTP 404;

            stop

        endif

    else (No)

        :Rechazar operación no autorizada;

        |Servicio interno autorizado|

        :Recibir error HTTP 401 o 403;

        stop

    endif


else (Eliminar)

    :Solicitar eliminación\nDELETE /api/v1/templates/{id};

    |API de Plantillas|

    :Validar autenticación\ny autorización;

    if (¿Usuario autorizado?) then (Sí)

        :Buscar plantilla por id;

        if (¿Plantilla existente?) then (Sí)

            :Verificar si la plantilla\npuede eliminarse;

            if (¿Plantilla en uso?) then (Sí)

                :Desactivar plantilla;

                note right
                Se recomienda eliminación lógica
                para conservar el historial.
                end note

                :Guardar estado INACTIVA;

                |Servicio interno autorizado|

                :Recibir confirmación de desactivación\nHTTP 200;

                stop

            else (No)

                :Eliminar o desactivar plantilla;

                :Guardar cambio\nen base de datos;

                |Servicio interno autorizado|

                :Recibir confirmación\nHTTP 204;

                stop

            endif

        else (No)

            :Rechazar eliminación por\nplantilla inexistente;

            |Servicio interno autorizado|

            :Recibir error HTTP 404;

            stop

        endif

    else (No)

        :Rechazar operación no autorizada;

        |Servicio interno autorizado|

        :Recibir error HTTP 401 o 403;

        stop

    endif

endif

legend right
|= Operación |= Endpoint |
| Crear | POST /api/v1/templates |
| Actualizar | PUT /api/v1/templates/{id} |
| Eliminar | DELETE /api/v1/templates/{id} |
endlegend

@enduml