@startuml reservas-09-bp-reserva
' ============================================================
' BP - Business Process (BPMN) del flujo de reserva
' Proceso: Reserva de vuelo/hotel con pago
' Notacion: Activity diagram con swimlanes (carriles por actor/backend)
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam ActivityFontColor #1A1A1A
skinparam ActivityBorderColor #1168BD
skinparam ActivityBorderThickness 1.2
skinparam ActivityBackgroundColor #FFFFFF
skinparam ActivityDiamondBackgroundColor #FFF3CD
skinparam ActivityDiamondBorderColor #E0A800
skinparam ActivityDiamondFontColor #1A1A1A
skinparam ArrowColor #1168BD
skinparam ArrowFontColor #1A1A1A
skinparam SwimlaneTitleFontColor #003865
skinparam SwimlaneTitleFontSize 14
skinparam SwimlaneBorderColor #9BB7D4

title Proceso de Negocio (BPMN) - Reserva de vuelo/hotel con pago

|#EAF2FB|Viajero|
start
:Ingresar criterios de busqueda\n(origen, destino, fechas, pasajeros);

|#FFFFFF|Servicio de Busqueda|
:Consultar disponibilidad y tarifas\n(GDS de vuelos / proveedor de hoteles);
:Normalizar y ordenar ofertas;

|Viajero|
:Revisar ofertas;
if (Encontro una oferta adecuada?) then (no)
  :Abandonar / nueva busqueda;
  stop
else (si)
  :Seleccionar oferta y cargar pasajeros;
endif

|#EAF2FB|Servicio de Reservas|
:Verificar disponibilidad de la oferta;
if (Hay disponibilidad?) then (no)
  :Rechazar (oferta expirada);
  |Viajero|
  :Recibir aviso de no disponibilidad;
  stop
else (si)
  :Crear reserva con bloqueo temporal (hold)\nestado = PENDIENTE;
endif

|Viajero|
:Realizar pago\n(medio de pago);

|#FFFFFF|Orquestador de Pagos|
:Registrar intento de pago (idempotente);
:Procesar cobro en la pasarela\n(con reintentos);

if (Pago aprobado?) then (si)
  :Marcar pago APROBADO;
  :Publicar evento PagoProcesado;

  |Servicio de Reservas|
  :Confirmar reserva definitiva ante proveedor;
  :Marcar reserva CONFIRMADA + localizador;
  :Publicar evento ReservaConfirmada;

  |#EAF2FB|Notificaciones|
  :Enviar comprobante (email / SMS);

  |Viajero|
  :Recibir confirmacion y comprobante;
  stop
else (no)
  |Orquestador de Pagos|
  :Marcar pago RECHAZADO;
  :Publicar evento PagoProcesado;

  |Servicio de Reservas|
  :Cancelar reserva\nestado = CANCELADA;
  :Liberar bloqueo (hold);

  |Viajero|
  :Recibir aviso de pago rechazado;
  stop
endif

legend bottom
  Camino alterno: si el viajero no paga antes de que expire el hold (TTL),
  un proceso programado marca la reserva como EXPIRADA y libera el inventario.
endlegend

@enduml
