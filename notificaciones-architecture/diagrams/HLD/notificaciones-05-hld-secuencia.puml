@startuml notificaciones-05-hld-secuencia
title HLD - Outbox, BullMQ y entrega
actor Emisor
participant "API REST" as api
database PostgreSQL as db
participant "Outbox Relay" as relay
queue "Redis / BullMQ" as queue
participant "EMAIL Worker" as worker
participant "Gmail SMTP" as gmail
Emisor -> api : POST notification + Idempotency-Key
api -> db : BEGIN; INSERT notification + outbox; COMMIT
db --> api : ENCOLADA
api --> Emisor : 202 (sin esperar Redis/SMTP)
loop lotes pendientes
  relay -> db : claim SKIP LOCKED
  db --> relay : eventos
  relay -> queue : addBulk(jobId determinista)
  relay -> db : marcar PUBLISHED
end
queue -> worker : job canal/generación
worker -> db : claim lease si ENCOLADA y generación vigente
worker -> gmail : sendMail(Message-ID determinista)
alt éxito
  gmail --> worker : ACK
  worker -> db : INSERT intento + UPDATE ENVIADA
else fallo temporal
  gmail --> worker : 421/450/451/452 o red
  worker -> db : INSERT intento, mantiene ENCOLADA
  worker --> queue : Error -> backoff exponencial
else fallo terminal/agota ciclo
  worker -> db : INSERT intento + UPDATE FALLIDA
  worker --> queue : UnrecoverableError
end
@enduml
