@startuml notificaciones-05-hld-secuencia
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam maxMessageSize 70
skinparam sequence {
    ArrowColor #1168BD
    LifeLineBorderColor #1168BD
    ParticipantBorderColor #003865
    ParticipantBackgroundColor #003865
    ParticipantFontColor #FFFFFF
    ActorBorderColor #003865
}

title HLD - Notificaciones con transactional outbox y BullMQ

actor "Servicio interno\n(previamente autenticado)" as emisor
participant "API REST" as api
database "PostgreSQL\nfuente de verdad" as db
participant "Outbox\nPublisher" as publisher
queue "BullMQ\nsobre Redis" as bull
participant "Worker\nde entregas" as worker
participant "Proveedor\npor canal" as provider

== Aceptación durable ==
emisor -> api : POST /api/v1/notifications\nIdempotency-Key
api -> api : validar request, plantilla y variables
alt request inválido
    api --> emisor : 400 o 404
else request válido
    api -> db : BEGIN; INSERT notificación ENCOLADA\nON CONFLICT DO NOTHING
    alt idempotency_key existente
        api -> db : COMMIT sin cambios; consultar y comparar payload
        api --> emisor : 200 existente o 409 conflicto
    else notificación nueva
        api -> db : INSERT notification_outbox; COMMIT
        api --> emisor : 202 Accepted
        note right of api
          La respuesta no espera a Redis.
          El outbox ya quedó confirmado.
        end note
    end
end

== Publicación recuperable ==
publisher -> db : reclamar evento pendiente\nFOR UPDATE SKIP LOCKED
publisher -> bull : add deliver-notification\njobId = outbox-{id}
alt Redis no disponible
    publisher -> db : incrementar publish_attempts y\nreprogramar available_at con backoff
else job creado o ya existente
    publisher -> db : marcar published_at
end

== Entrega y reintentos automáticos ==
bull -> worker : job disponible tras rate limiter
worker -> db : advisory lock + consultar\nnotificación y plantilla
alt estado ENVIADA
    worker --> bull : completar como omitido
else entrega pendiente
    worker -> provider : enviar por SMTP o HTTPS
    provider --> worker : éxito o error
    alt éxito
        worker -> db : INSERT intento EXITOSO + estado ENVIADA
    else error transitorio y quedan intentos
        worker -> db : INSERT intento FALLIDO + estado ENCOLADA
        worker --> bull : lanzar error
        bull -> bull : reintentar con backoff exponencial
    else error permanente o máximo alcanzado
        worker -> db : INSERT intento FALLIDO + estado FALLIDA
        worker --> bull : UnrecoverableError
    end
end
worker -> db : liberar advisory lock

== Reintento manual ==
emisor -> api : POST /api/v1/notifications/{id}/retry
api -> db : BEGIN; SELECT FOR UPDATE; validar FALLIDA\nUPDATE ENCOLADA; INSERT outbox diferido; COMMIT
alt permitido
    api --> emisor : 202 Accepted
else inexistente o no permitido
    api --> emisor : 404 o 409
end

note over db,bull
  PostgreSQL conserva el estado de negocio.
  Redis conserva solo jobs y metadatos operativos de BullMQ.
end note

@enduml
