@startuml notificaciones-07-lld-plantillas
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam maxMessageSize 65
skinparam sequence {
    ArrowColor #1168BD
    LifeLineBorderColor #1168BD
    ParticipantBorderColor #003865
    ParticipantBackgroundColor #003865
    ParticipantFontColor #FFFFFF
    ActorBorderColor #003865
}

title LLD - Gestión de plantillas

actor "Servicio interno" as emisor
participant "Middleware\nZod" as validation
participant "Template\nController" as controller
participant "Template\nService" as service
participant "Template\nRepository" as repository
database "PostgreSQL" as db

== Crear ==
emisor -> validation : POST /api/v1/templates
validation -> validation : validar body estricto y\nvariables no repetidas
alt body inválido
    validation --> emisor : 400
else body válido
    validation -> controller : create(body)
    controller -> service : createTemplateService(body)
    service -> repository : insertTemplate(body)
    repository -> db : INSERT ... ON CONFLICT DO NOTHING
    alt nombre + canal duplicados
        controller --> emisor : 409
    else creada
        controller --> emisor : 201 + plantilla
    end
end

== Actualizar ==
emisor -> validation : PUT /api/v1/templates/{id}
validation -> validation : validar BIGINT y body completo
validation -> controller : update(id, body)
controller -> service : updateTemplateService(id, body)
service -> repository : updateTemplateById(id, body)
repository -> db : UPDATE si no existe otro nombre + canal
alt actualizada
    controller --> emisor : 200 + plantilla
else sin fila actualizada
    service -> repository : findTemplateById(id)
    repository -> db : SELECT plantilla
    alt no existe
        controller --> emisor : 404
    else conflicto de nombre + canal
        controller --> emisor : 409
    end
end

== Eliminar ==
emisor -> validation : DELETE /api/v1/templates/{id}
validation -> controller : id BIGINT válido
controller -> service : deleteTemplateService(id)
service -> repository : deleteTemplateById(id)
repository -> db : DELETE si no hay notificaciones asociadas
alt eliminada
    controller --> emisor : 204 sin body
else sin fila eliminada
    service -> repository : findTemplateById(id)
    repository -> db : SELECT plantilla
    alt no existe
        controller --> emisor : 404
    else tiene notificaciones
        controller --> emisor : 409
    end
end

@enduml
