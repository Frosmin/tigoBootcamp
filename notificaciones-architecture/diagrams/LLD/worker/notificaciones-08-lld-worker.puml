@startuml notificaciones-08-lld-worker
' ============================================================
' LLD - Diagrama de Secuencia (Bajo Nivel)
' Componente: Worker de Envíos
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam sequence {
    ArrowColor #1168BD
    ArrowFontColor #333333
    LifeLineBorderColor #1168BD
    LifeLineBackgroundColor #D6E4F0
    ParticipantBorderColor #003865
    ParticipantBackgroundColor #003865
    ParticipantFontColor #FFFFFF
    ActorBorderColor #003865
    ActorBackgroundColor #003865
    BoxBorderColor #1168BD
    BoxFontColor #003865
}
skinparam noteBackgroundColor #FFF3CD
skinparam noteBorderColor #E0A800

title LLD - Worker de Envíos (Node.js / Redis / Tigo Library)

participant "Redis\nCola y coordinación" as redis

box "Worker de Envíos" #EAF2FB
    participant "Procesador de\nEnvíos" as worker
    participant "Repositorio de\nNotificaciones" as notificationRepo
    participant "Repositorio de\nPlantillas" as templateRepo
    participant "Repositorio de\nIntentos" as attemptRepo
    participant "Renderizador de\nPlantillas" as renderer
    participant "Limitador de\nThroughput" as limiter
    participant "Control de\nEntrega" as guard
    participant "Política de\nReintentos" as retryPolicy
    participant "Conector email/SMS\nTigo Library" as connector
end box

database "PostgreSQL" as db
participant "Proveedor de\nemail/SMS" as proveedor

autonumber "<b>[00]"

loop por cada trabajo disponible
    worker -> redis : siguiente()
    activate worker
    redis --> worker : notificacionId

    worker -> notificationRepo : findById(notificacionId)
    activate notificationRepo
    notificationRepo -> db : SELECT notificacion WHERE id=?
    db --> notificationRepo : notificacion | null
    notificationRepo --> worker : notificacion | null
    deactivate notificationRepo

    alt trabajo sin notificación asociada
        worker -> worker : registra y descarta trabajo huérfano
    else notificación encontrada
        worker -> guard : fueEntregada(notificacionId, estado)
        activate guard
        guard -> redis : GET delivered:{id}
        redis --> guard : marca | null
        guard --> worker : entregada | pendiente
        deactivate guard

        alt estado ENVIADA o marca de entrega existente
            worker -> worker : descarta trabajo duplicado
        else entrega pendiente
            worker -> limiter : adquirirPermiso()
            activate limiter
            limiter -> redis : INCR contador de ventana actual
            redis --> limiter : consumo y TTL
            limiter --> worker : permitido | limitado
            deactivate limiter

            alt throughput por minuto agotado
                worker -> redis : encolarDiferido(id, siguienteVentana)
                note right of worker
                  La reprogramación por capacidad
                  no consume un intento de entrega.
                end note
            else permiso concedido
                worker -> templateRepo : findById(plantillaId)
                activate templateRepo
                templateRepo -> db : SELECT plantilla WHERE id=?
                db --> templateRepo : plantilla
                templateRepo --> worker : plantilla
                deactivate templateRepo

                worker -> renderer : renderizar(plantilla, variables)
                activate renderer
                renderer --> worker : contenido final
                deactivate renderer

                worker -> connector : enviar(canal, destinatario, contenido)
                activate connector
                connector -> proveedor : entregar email o SMS
                activate proveedor
                proveedor --> connector : éxito | fallo(código, detalle)
                deactivate proveedor
                connector --> worker : DeliveryResult
                deactivate connector

                alt entrega exitosa
                    worker -> attemptRepo : save(EXITOSO, detalle)
                    activate attemptRepo
                    attemptRepo -> db : INSERT INTO intentos ...
                    db --> attemptRepo : intento registrado
                    attemptRepo --> worker : ok
                    deactivate attemptRepo

                    worker -> notificationRepo : marcarEnviada(id)
                    notificationRepo -> db : UPDATE notificaciones\nSET estado='ENVIADA', intentos=intentos+1
                    worker -> guard : marcarEntregada(id)
                    guard -> redis : SET delivered:{id} NX
                else entrega fallida
                    worker -> attemptRepo : save(FALLIDO, código, detalle)
                    activate attemptRepo
                    attemptRepo -> db : INSERT INTO intentos ...
                    db --> attemptRepo : intento registrado
                    attemptRepo --> worker : ok
                    deactivate attemptRepo

                    worker -> notificationRepo : incrementarIntentos(id)
                    notificationRepo -> db : UPDATE notificaciones\nSET intentos=intentos+1
                    worker -> retryPolicy : evaluar(error, notificacion)
                    activate retryPolicy
                    retryPolicy -> retryPolicy : verifica error reintentable\ny máximo configurable

                    alt error reintentable y quedan intentos
                        retryPolicy -> retryPolicy : calcularDemora(numeroIntento)
                        retryPolicy --> worker : reintentar(demora)
                        deactivate retryPolicy
                        worker -> redis : encolarDiferido(id, demora)
                        worker -> notificationRepo : mantener estado=ENCOLADA
                        notificationRepo -> db : UPDATE notificaciones SET estado='ENCOLADA'
                    else error terminal o máximo alcanzado
                        retryPolicy --> worker : finalizar como FALLIDA
                        deactivate retryPolicy
                        worker -> notificationRepo : marcarFallida(id)
                        notificationRepo -> db : UPDATE notificaciones SET estado='FALLIDA'
                    end
                end
            end
        end
    end
    deactivate worker
end

note over worker, redis
  El backoff se implementa como trabajo diferido.
  El worker libera el ciclo y nunca espera la demora.
end note

note over guard, proveedor
  La comprobación antes del envío y la marca posterior
  evitan entregar dos veces una notificación ya completada.
end note

@enduml
