@startuml notificaciones-06-lld-notificaciones
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceMessageAlign center
title LLD - Procesamiento de una notificación

participant "DeliveryWorker" as runner
participant "WorkerQueue" as queue
participant "DeliveryProcessor" as processor
database "PostgreSQL" as db
participant "Renderer" as renderer
participant "Connector" as connector
participant "Gmail SMTP" as gmail

runner -> queue : XAUTOCLAIM o XREADGROUP
queue --> runner : messageId + notificationId
runner -> processor : process(notificationId)
processor -> queue : SET lock NX PX
alt lock ocupado
  processor --> runner : DUPLICATE_LOCKED
else lock adquirido
  processor -> db : SELECT notificación + plantilla
  alt no existe, ENVIADA o FALLIDA
    processor --> runner : descartar de forma segura
  else ENCOLADA
    processor -> queue : GET delivered
    alt delivered existente
      processor -> db : EXITOSO + ENVIADA atómico
    else no entregada
      processor -> renderer : renderTemplate
      processor -> queue : permiso por canal
      alt sin permiso
        processor -> queue : ZADD sin consumir intento
      else EMAIL
        processor -> connector : sendMail
        connector -> gmail : SMTP + Message-ID determinista
        gmail --> connector : éxito o error
        alt éxito
          processor -> queue : SET delivered
          processor -> db : EXITOSO + ENVIADA atómico
        else reintentable y no agotado
          processor -> db : FALLIDO + ENCOLADA + next_attempt_at
          processor -> queue : ZADD con backoff
        else terminal o agotado
          processor -> db : FALLIDO + FALLIDA atómico
        end
      else SMS
        processor -> db : FALLIDO + FALLIDA\nSMS_PROVIDER_NOT_CONFIGURED
      end
    end
  end
  processor -> queue : liberar lock con token (Lua)
  processor --> runner : outcome
end
runner -> queue : XACK messageId

note over runner,queue
Si falla el procesamiento antes de persistir,
no hay XACK y XAUTOCLAIM recuperará el pendiente.
end note
@enduml
