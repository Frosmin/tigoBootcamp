@startuml notificaciones-06-lld-notificaciones
title LLD - Crear, publicar y procesar
participant Controller
participant NotificationService
participant Renderer
participant NotificationRepository
database PostgreSQL
participant OutboxPublisher
participant "BullMQ Queue" as Queue
participant "BullMQ Worker" as Worker
participant DeliveryConnector
Controller -> NotificationService : create(body, idempotencyKey)
NotificationService -> Renderer : validate + render snapshot
NotificationService -> NotificationRepository : insert aggregate
NotificationRepository -> PostgreSQL : transaction notification + outbox
NotificationService --> Controller : 202/200/409
OutboxPublisher -> PostgreSQL : claim batch
OutboxPublisher -> Queue : addBulk
OutboxPublisher -> PostgreSQL : published
Queue -> Worker : job
Worker -> PostgreSQL : conditional lease
Worker -> DeliveryConnector : send(snapshot)
Worker -> PostgreSQL : attempt + state transaction
@enduml
