@startuml notificaciones-01-bp-envio
title Envío asíncrono de notificación

skinparam backgroundColor white
skinparam shadowing false
skinparam activity {
  BackgroundColor white
  BorderColor #1676D2
  DiamondBackgroundColor #FFF2CC
  DiamondBorderColor #C99A00
  StartColor #222222
  EndColor #222222
}

|Servicio interno|
start
:POST /api/v1/notifications\nHeader Idempotency-Key;

|API REST|
:Validar header, body, canal,\ndestinatario y variables;
:Consultar plantilla;
if (¿Solicitud válida?) then (sí)
  :Insertar ENCOLADA con\nidempotency_key única;
  if (¿Clave existente?) then (sí)
    if (¿Mismo payload?) then (sí)
      |Servicio interno|
      :HTTP 200 recurso existente;
      stop
    else (no)
      |Servicio interno|
      :HTTP 409 CF001;
      stop
    endif
  else (no)
    |API REST|
    :XADD notificationId\na notifications:dispatch;
    if (¿XADD exitoso?) then (sí)
      |Servicio interno|
      :HTTP 202 ENCOLADA;
    else (no)
      |API REST|
      :DELETE compensatorio;
      |Servicio interno|
      :HTTP 503 SU001;
      stop
    endif
  endif
else (no)
  |Servicio interno|
  :HTTP 400 o 404;
  stop
endif

|Worker|
:XREADGROUP / XAUTOCLAIM;
:Adquirir lock por notificación;
:Consultar notificación y plantilla;
if (¿ENVIADA, FALLIDA o delivered?) then (sí)
  :No volver a enviar;
  :Persistir recuperación si aplica;
else (no)
  :Aplicar límite por canal;
  if (¿Hay capacidad?) then (sí)
    :Renderizar {{variables}};
    if (¿Canal EMAIL?) then (sí)
      :Enviar con Nodemailer / Gmail SMTP\ny Message-ID determinista;
    else (SMS)
      :Fallo terminal\nSMS_PROVIDER_NOT_CONFIGURED;
    endif
    if (¿Entrega exitosa?) then (sí)
      :Marcar delivered en Redis;
      :Registrar EXITOSO y ENVIADA\nen una sentencia SQL;
    else (no)
      if (¿Reintentable y quedan intentos?) then (sí)
        :Registrar FALLIDO, ENCOLADA\ny next_attempt_at;
        :ZADD notifications:delayed\ncon backoff exponencial;
      else (no)
        :Registrar FALLIDO y FALLIDA\nen una sentencia SQL;
      endif
    endif
  else (no)
    :ZADD diferido sin consumir intento;
  endif
endif
:Liberar lock;
:XACK después de persistir;
stop

legend right
  El promotor Lua mueve trabajos vencidos
  desde notifications:delayed al stream.
endlegend
@enduml
