@startuml notificaciones-01-bp-envio
title BP - Envío durable de notificación
|Servicio interno|
start
:POST /api/v1/notifications\nIdempotency-Key;
|API REST|
:Validar Zod, plantilla, canal y variables;
if (¿Válida?) then (sí)
  :Renderizar snapshot;
  :BEGIN PostgreSQL;
  :INSERT notificación ENCOLADA;
  :INSERT outbox generación 1;
  :COMMIT;
  if (¿Clave existente?) then (sí)
    :Comparar payload;
    |Servicio interno|
    :200 existente o 409 conflicto;
    stop
  else (no)
    |Servicio interno|
    :202 Accepted;
  endif
else (no)
  |Servicio interno|
  :400 / 404 / 503;
  stop
endif
|Outbox Relay|
:Reclamar lote con SKIP LOCKED;
:BullMQ addBulk\njobId notification-id-generation;
:Marcar outbox PUBLISHED;
|BullMQ Worker|
:Aplicar rate limit global;
:Claim PostgreSQL con lease;
if (¿Ya enviada o generación vieja?) then (sí)
  :Completar sin entregar;
  stop
else (no)
  :Enviar por conector;
  if (¿Éxito?) then (sí)
    :Registrar intento + ENVIADA;
  else (no)
    :Registrar intento FALLIDO;
    if (¿Temporal y quedan intentos?) then (sí)
      :Lanzar Error; BullMQ aplica backoff;
    else (no)
      :Marcar FALLIDA y UnrecoverableError;
    endif
  endif
endif
stop
@enduml
