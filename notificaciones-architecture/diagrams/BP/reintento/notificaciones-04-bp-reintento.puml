@startuml notificaciones-04-bp-reintento
title BP - Reintento manual
|Servicio interno|
start
:POST /api/v1/notifications/{id}/retry;
|API REST|
:Validar BIGINT;
:Bloquear notificación FOR UPDATE;
if (¿Existe?) then (sí)
  if (¿Estado FALLIDA?) then (sí)
    if (¿Intentos < máximo total?) then (sí)
      :Actualizar ENCOLADA y generación + 1;
      :Insertar outbox en misma transacción;
      |Servicio interno|
      :202 Accepted;
    else (no)
      |Servicio interno|
      :409 máximo alcanzado;
    endif
  else (no)
    |Servicio interno|
    :409 ENCOLADA o ENVIADA;
  endif
else (no)
  |Servicio interno|
  :404;
endif
stop
@enduml
