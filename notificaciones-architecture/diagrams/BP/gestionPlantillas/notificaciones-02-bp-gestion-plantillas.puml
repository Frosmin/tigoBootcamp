@startuml notificaciones-02-bp-gestion-plantillas

title Gestión de Plantillas

skinparam backgroundColor white
skinparam shadowing false
skinparam activity {
    BackgroundColor white
    BorderColor #1676D2
    FontColor #000000
    DiamondBackgroundColor #FFF2CC
    DiamondBorderColor #C99A00
    StartColor #222222
    EndColor #222222
    BarColor #1676D2
}
skinparam swimlane {
    BorderColor #8AB4E8
    TitleBackgroundColor #E8F1FB
    TitleFontColor #003B70
}

|Servicio interno autorizado|
start
:Seleccionar operación\ncrear, actualizar o eliminar;

if (¿Operación?) then (Crear)
    :Enviar nombre, canal, contenido\ny variables[]\nPOST /api/v1/templates;
    |API REST|
    :Validar autenticación, autorización\ny datos con Zod;
    if (¿Datos válidos?) then (Sí)
        :Buscar nombre y canal\nen PostgreSQL;
        if (¿Nombre único por canal?) then (Sí)
            :Persistir nueva plantilla;
            |Servicio interno autorizado|
            :Recibir HTTP 201\ny plantilla creada;
            stop
        else (No)
            :Rechazar nombre duplicado;
            |Servicio interno autorizado|
            :Recibir HTTP 409;
            stop
        endif
    else (No)
        :Rechazar datos o credenciales;
        |Servicio interno autorizado|
        :Recibir HTTP 400, 401 o 403;
        stop
    endif

elseif (¿Operación?) then (Actualizar)
    :Enviar cambios\nPUT /api/v1/templates/{id};
    |API REST|
    :Validar autenticación, autorización\ny datos con Zod;
    if (¿Solicitud válida?) then (Sí)
        :Buscar plantilla por id\nen PostgreSQL;
        if (¿Plantilla existente?) then (Sí)
            :Comprobar nombre único por canal\nexcluyendo la plantilla actual;
            if (¿Existe otro nombre igual\nen el canal?) then (Sí)
                :Rechazar nombre duplicado;
                |Servicio interno autorizado|
                :Recibir HTTP 409;
                stop
            else (No)
                :Persistir cambios;
                |Servicio interno autorizado|
                :Recibir HTTP 200\ny plantilla actualizada;
                stop
            endif
        else (No)
            :Rechazar plantilla inexistente;
            |Servicio interno autorizado|
            :Recibir HTTP 404;
            stop
        endif
    else (No)
        :Rechazar datos o credenciales;
        |Servicio interno autorizado|
        :Recibir HTTP 400, 401 o 403;
        stop
    endif

else (Eliminar)
    :Solicitar eliminación\nDELETE /api/v1/templates/{id};
    |API REST|
    :Validar autenticación y autorización;
    if (¿Solicitud autorizada?) then (Sí)
        :Buscar plantilla por id\nen PostgreSQL;
        if (¿Plantilla existente?) then (Sí)
            :Eliminar plantilla\nsegún la política del dominio;
    
            |Servicio interno autorizado|
            :Recibir HTTP 204;
            stop
        else (No)
            :Rechazar plantilla inexistente;
            |Servicio interno autorizado|
            :Recibir HTTP 404;
            stop
        endif
    else (No)
        :Rechazar operación no autorizada;
        |Servicio interno autorizado|
        :Recibir HTTP 401 o 403;
        stop
    endif
endif

legend right
|= RF-7.2 |= Endpoint |
| Crear | POST /api/v1/templates |
| Actualizar | PUT /api/v1/templates/{id} |
| Eliminar | DELETE /api/v1/templates/{id} |
endlegend

@enduml
