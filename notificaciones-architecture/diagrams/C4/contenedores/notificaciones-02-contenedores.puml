@startuml notificaciones-02-contenedores
!define RELATIVE_INCLUDE "."
!include ../../../../notificaciones-architecture/binariess/C4_Container.puml

LAYOUT_LEFT_RIGHT()
title Diagrama de Contenedores (C2) - Notificaciones

Person(emisores, "Emisores", "Servicios internos autenticados previamente.")
System_Ext(gmail, "Gmail SMTP", "Entrega correo mediante SMTP seguro.")

System_Boundary(p07, "Microservicio P07 Notificaciones") {
  Container(api, "API REST", "Node.js / ultimate-express / Zod", "Crea y consulta notificaciones y administra plantillas.")
  Container(worker, "Worker de envíos", "Node.js 22 / Nodemailer", "Consume grupos Redis, entrega EMAIL y registra resultados. SMS aún no tiene proveedor.")
  ContainerDb(db, "Base de datos", "PostgreSQL", "Fuente de verdad para plantillas, idempotencia, estados e intentos.")
  ContainerDb(redis, "Cola y coordinación", "Redis Streams + Sorted Sets", "Stream, pendientes, reintentos diferidos, locks, delivered y throughput.")
}

Rel(emisores, api, "Crea y consulta", "HTTPS / JSON")
Rel(api, db, "SQL parametrizado")
Rel(api, redis, "XADD notificationId", "RESP")
Rel(worker, redis, "XREADGROUP, XAUTOCLAIM, XACK, ZSET y locks", "RESP")
Rel(worker, db, "Lee plantilla; registra intento y estado atómicamente", "SQL")
Rel(worker, gmail, "EMAIL con Message-ID determinista", "SMTP TLS")

SHOW_LEGEND()
@enduml
