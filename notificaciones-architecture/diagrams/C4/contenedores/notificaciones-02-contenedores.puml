@startuml notificaciones-02-contenedores
!include ../../../../notificaciones-architecture/binariess/C4_Container.puml
LAYOUT_LEFT_RIGHT()
title C2 - Contenedores P07 Notificaciones
Person(emisores, "Servicios internos", "Emisores autenticados.")
System_Ext(gmail, "Gmail SMTP", "Proveedor externo de email.")
System_Ext(sms, "SMS futuro", "Proveedor aún no definido.")
System_Boundary(p07, "P07 Notificaciones") {
  Container(api, "API REST", "Node.js 22 / ultimate-express / Zod", "Valida, persiste y consulta sin depender de Redis.")
  Container(relay, "Outbox Relay", "Node.js 22 / BullMQ Queue", "Reclama outbox por lotes y publica jobs idempotentes.")
  Container(workerEmail, "Worker EMAIL", "Node.js 22 / BullMQ Worker / Nodemailer", "Aplica rate limit, backoff y entrega SMTP.")
  Container(workerSms, "Worker SMS futuro", "Node.js 22 / BullMQ Worker", "Puerto deshabilitado hasta definir proveedor.")
  ContainerDb(db, "PostgreSQL", "PostgreSQL 15", "Fuente de verdad: plantillas, snapshots, estado, intentos y outbox.")
  ContainerDb(redis, "Redis + BullMQ", "Redis 8 AOF/noeviction", "Colas por canal, delayed jobs, locks y métricas.")
}
Rel(emisores, api, "RF-7.1 a RF-7.5", "HTTPS/REST/JSON")
Rel(api, db, "Transacciones y consultas", "SQL")
Rel(relay, db, "FOR UPDATE SKIP LOCKED", "SQL")
Rel(relay, redis, "Queue.addBulk con jobId determinista", "RESP")
Rel(workerEmail, redis, "Consume, limita y reintenta", "RESP")
Rel(workerEmail, db, "Claim lease y registra intentos/estado", "SQL")
Rel(workerEmail, gmail, "Mensaje con Message-ID estable", "SMTP/TLS")
Rel(workerSms, sms, "Integración futura", "API")
SHOW_LEGEND()
@enduml
