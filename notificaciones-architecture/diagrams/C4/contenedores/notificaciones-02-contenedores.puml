@startuml notificaciones-02-contenedores
!define RELATIVE_INCLUDE "."
!include ../../../../notificaciones-architecture/binariess/C4_Container.puml

LAYOUT_LEFT_RIGHT()

title Diagrama de Contenedores (C2) - Notificaciones

Person(emisores, "Emisores", "Servicios internos.")
System_Ext(proveedor, "Proveedor de email y SMS", "Servicio genérico de terceros que entrega mensajes por email y SMS.")

System_Boundary(p07, "Microservicio P07 Notificaciones") {
    Container(api, "API REST", "Node.js / ultimate-express / Zod", "Expone api para crear y consultar notificaciones, reintentar fallos y administrar plantillas.")
    Container(worker, "Worker de envíos", "Node.js 22", "Consume trabajos pendientes, renderiza plantillas, controla el throughput, realiza envíos y programa reintentos con backoff exponencial.")
    ContainerDb(db, "Base de datos", "PostgreSQL", "Persiste plantillas, notificaciones, estados e intentos de entrega.")
    ContainerDb(redis, "Cola y coordinación", "Redis", "Mantiene la cola, trabajos diferidos, claves de idempotencia y contadores de throughput.")
}

Rel(emisores, api, "Envía, consulta, reintenta, lista y gestiona plantillas", "HTTPS / REST / JSON")
Rel(api, db, "Lee y persiste plantillas, notificaciones e intentos", "SQL")
Rel(api, redis, "Encola envíos y reintentos; verifica idempotencia", "RESP")

Rel(worker, redis, "Consume trabajos y aplica backoff, idempotencia y límite por minuto", "RESP")
Rel(worker, db, "Lee plantillas y actualiza estados e intentos", "SQL")
Rel(worker, proveedor, "Envía email o SMS mediante un conector genérico", "Librería sms y email / HTTPS")
Rel(proveedor, worker, "Devuelve éxito o fallo", "Respuesta API")

SHOW_LEGEND()
@enduml
