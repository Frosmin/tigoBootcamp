@startuml notificaciones-04-clases
title Modelo y colaboradores principales
hide empty members
class Plantilla {
  id: bigint
  nombre: string
  canal: Canal
  contenido: text
  variables: string[]
  deletedAt
}
class Notificacion {
  id: bigint
  estado: Estado
  intentos: int
  generacion: int
  asunto
  contenidoRenderizado
  processingToken
}
class Intento {
  numero: int
  generacion: int
  resultado
  retryable
  providerMessageId
}
class OutboxEvent {
  id: bigint
  aggregateId: bigint
  generation: int
  status
  lockedUntil
  payload
}
enum Canal {
  EMAIL
  SMS
}
enum Estado {
  ENCOLADA
  ENVIADA
  FALLIDA
}
interface DeliveryConnector {
  verify()
  send(notificacion)
  close()
}
class EmailConnector
class SmsConnectorFuturo
class OutboxPublisher {
  publishOnce()
  run()
  stop()
}
class BullMQQueue {
  addBulk()
}
class DeliveryWorker {
  process(job)
  close()
}
Plantilla "1" <-- "*" Notificacion
Notificacion "1" *-- "*" Intento
Notificacion "1" *-- "*" OutboxEvent
Notificacion --> Canal
Notificacion --> Estado
EmailConnector ..|> DeliveryConnector
SmsConnectorFuturo ..|> DeliveryConnector
OutboxPublisher --> OutboxEvent
OutboxPublisher --> BullMQQueue
DeliveryWorker --> DeliveryConnector
DeliveryWorker --> Notificacion
@enduml
