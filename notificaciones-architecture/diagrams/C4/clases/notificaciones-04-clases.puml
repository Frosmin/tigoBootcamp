@startuml notificaciones-04-clases
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #1168BD
  ArrowColor #1168BD
}
title Diagrama de Clases y Módulos (C4) - Worker

package "Dominio" {
  class TemplateRenderer {
    +renderTemplate(content, variables): string
  }
  class RetryPolicy {
    +calculateRetryDelay(attempt, baseMs, maxMs): number
  }
  class DeliveryError {
    +code: string
    +retryable: boolean
    +cause: Error
  }
}

package "Entrega" {
  interface DeliveryConnector {
    +send(message): DeliveryResult
  }
  class EmailConnector {
    -transporter: NodemailerTransporter
    -from: string
    -messageIdDomain: string
    +send(message): DeliveryResult
  }
  class SmsConnector {
    +send(message): DeliveryResult
  }
}
EmailConnector ..|> DeliveryConnector
SmsConnector ..|> DeliveryConnector
EmailConnector ..> DeliveryError
SmsConnector ..> DeliveryError

package "Aplicación" {
  class DeliveryProcessor {
    +process(notificationId): ProcessingOutcome
  }
  class DeliveryWorker {
    +run(processNotification, consumerName, signal): void
  }
}

package "Persistencia" {
  class NotificationRepository {
    +findNotificationForDelivery(id): Notification
  }
  class AttemptRepository {
    +recordDeliveryAttempt(command): Attempt
  }
}

package "Redis" {
  class WorkerQueue {
    +ensureConsumerGroup(): void
    +readMessages(consumer): Message[]
    +claimStaleMessages(consumer): Message[]
    +acknowledge(messageId): void
    +schedule(notificationId, dueAt): void
    +promoteDue(): number
    +acquireLock(notificationId, token): boolean
    +releaseLock(notificationId, token): void
    +isMarkedDelivered(notificationId): boolean
    +markDelivered(notificationId): void
    +acquireThroughputPermit(channel, limit): Permit
  }
}

DeliveryWorker --> WorkerQueue : claim/read/ack/promote
DeliveryWorker --> DeliveryProcessor
DeliveryProcessor --> NotificationRepository
DeliveryProcessor --> AttemptRepository
DeliveryProcessor --> WorkerQueue
DeliveryProcessor --> TemplateRenderer
DeliveryProcessor --> RetryPolicy
DeliveryProcessor --> EmailConnector
DeliveryProcessor --> SmsConnector

note right of AttemptRepository
El UPDATE de notificación y el INSERT
del intento comparten una sentencia SQL.
end note

note bottom of WorkerQueue
Consumer group desde 0, XAUTOCLAIM,
ZSET diferido, scripts Lua, locks y rate limit.
end note
@enduml
