@startuml notificaciones-03-componentes
!include ../../../../notificaciones-architecture/binariess/C4_Component.puml
LAYOUT_LEFT_RIGHT()
title C3 - Componentes P07 Notificaciones
ContainerDb(db, "PostgreSQL", "postgres", "Estado, intentos y outbox.")
ContainerDb(redis, "Redis/BullMQ", "redis", "Jobs y coordinación.")
System_Ext(gmail, "Gmail SMTP", "Proveedor externo.")
Container_Boundary(api, "API Node.js") {
  Component(routes, "REST + validación", "ultimate-express / Zod", "Contratos /api/v1 y errores estándar.")
  Component(services, "Casos de uso", "JavaScript", "Plantillas, snapshots, idempotencia, cursor y retry.")
  Component(repos, "Repositorios", "@tigo/postgres-connector", "SQL parametrizado y transacciones.")
  Component(renderer, "Renderer", "Dominio", "Valida placeholders y congela contenido.")
}
Container_Boundary(background, "Procesamiento Node.js") {
  Component(outbox, "Outbox Publisher", "BullMQ Queue", "Claims con lease y addBulk.")
  Component(worker, "Delivery Worker", "BullMQ Worker", "Claim, rate limit, retries y stalled recovery.")
  Component(connector, "Email Connector", "Nodemailer", "Pool SMTP, TLS y Message-ID determinista.")
  Component(events, "Queue Events", "BullMQ", "Telemetría de fallos y stalled.")
}
Rel(routes, services, "Ejecuta")
Rel(services, renderer, "Valida/renderiza")
Rel(services, repos, "Lee/escribe")
Rel(repos, db, "SQL")
Rel(outbox, db, "Reclama/marca")
Rel(outbox, redis, "Publica")
Rel(worker, redis, "Consume")
Rel(worker, repos, "Actualiza")
Rel(worker, connector, "Envía")
Rel(connector, gmail, "SMTP/TLS")
Rel(events, redis, "Escucha")
SHOW_LEGEND()
@enduml
