@startuml notificaciones-03-componentes
!define RELATIVE_INCLUDE "."
!include ../../../../notificaciones-architecture/binariess/C4_Component.puml

LAYOUT_LEFT_RIGHT()
title Diagrama de Componentes (C3) - Notificaciones

Person(emisores, "Emisores", "Servicios internos")
System_Ext(gmail, "Gmail SMTP", "Proveedor EMAIL")
ContainerDb(db, "PostgreSQL", "postgres", "Idempotencia, notificaciones, plantillas e intentos")
ContainerDb(redis, "Redis", "Streams / ZSET", "Cola y coordinación")

Container_Boundary(api, "API REST") {
  Component(routes, "Rutas, validación y controladores", "ultimate-express / Zod", "Expone POST/GET y errores estandarizados")
  Component(notificationService, "Servicio de notificaciones", "Aplicación", "Valida plantilla, crea, deduplica y consulta")
  Component(repositories, "Repositorios", "postgres-connector", "SQL parametrizado")
  Component(publisher, "Publicador", "ioredis", "XADD del notificationId")
}

Container_Boundary(worker, "Worker independiente") {
  Component(runner, "Consumer runner", "Redis consumer group", "Crea grupo, reclama pendientes, lee y confirma")
  Component(processor, "Delivery processor", "Aplicación", "Coordina lock, estado, renderizado, entrega y persistencia")
  Component(renderer, "Template renderer", "Dominio", "Sustituye variables y rechaza tokens pendientes")
  Component(retry, "Retry policy", "Dominio", "Backoff exponencial y máximo configurable")
  Component(workerQueue, "Worker queue adapter", "ioredis + Lua", "ZSET, promoción, locks, delivered y rate limit")
  Component(attemptRepo, "Attempt repository", "postgres-connector", "Actualiza estado e inserta intento en una sentencia")
  Component(email, "EmailConnector", "Nodemailer", "Gmail SMTP y Message-ID determinista")
  Component(sms, "SmsConnector", "Placeholder", "Fallo terminal mientras no exista proveedor")
}

Rel(emisores, routes, "HTTPS / JSON")
Rel(routes, notificationService, "Casos de uso")
Rel(notificationService, repositories, "Lee y persiste")
Rel(notificationService, publisher, "Encola")
Rel(repositories, db, "SQL")
Rel(publisher, redis, "XADD")

Rel(runner, workerQueue, "Claim/read/ACK")
Rel(runner, processor, "notificationId")
Rel(processor, repositories, "Obtiene notificación y plantilla")
Rel(processor, attemptRepo, "Registra resultado")
Rel(processor, renderer, "Renderiza")
Rel(processor, retry, "Calcula demora")
Rel(processor, workerQueue, "Lock, delivered, rate y ZADD")
Rel(processor, email, "Entrega EMAIL")
Rel(processor, sms, "Procesa SMS")
Rel(workerQueue, redis, "RESP / Lua")
Rel(attemptRepo, db, "SQL atómico")
Rel(email, gmail, "SMTP TLS")

SHOW_LEGEND()
@enduml
