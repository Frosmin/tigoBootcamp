@startuml notificaciones-03-componentes

!define RELATIVE_INCLUDE "."
!include ../../../../notificaciones-architecture/binariess/C4_Component.puml

LAYOUT_TOP_DOWN()

title Diagrama de Componentes (C3) - Notificaciones

Person(emisores, "Servicios internos", "Consumidores previamente autenticados.")
System_Ext(gmail, "Gmail SMTP", "Proveedor externo de email.")
System_Ext(sms, "Twilio", "Proveedor externo de SMS.")
ContainerDb(db, "PostgreSQL", "Fuente de verdad", "Plantillas, notificaciones, intentos y notification_outbox.")
ContainerQueue(redis, "BullMQ sobre Redis", "Infraestructura operativa", "Jobs, backoff y rate limiting; sin estado de negocio.")

Container_Boundary(api, "API REST") {
    Component(http, "Capa HTTP", "Routes / Zod / Controllers", "Valida requests y traduce resultados a respuestas estandarizadas.")
    Component(apiServices, "Servicios de aplicación", "NotificationService / TemplateService", "Aplica idempotencia, reglas de plantillas, consultas y reintento manual.")
    Component(apiPersistence, "Persistencia transaccional", "Repositories / withTransaction", "Guarda notificación y outbox atómicamente; consulta y modifica el estado de negocio.")
}

Container_Boundary(runtime, "Worker y Outbox Publisher") {
    Component(publisher, "Outbox Publisher", "Polling PostgreSQL", "Reclama eventos pendientes y los publica como jobs BullMQ con jobId estable.")
    Component(queueModule, "Cola de notificaciones", "BullMQ Queue", "Configura intentos, backoff exponencial y retención de jobs.")
    Component(processor, "Procesador de entrega", "BullMQ Worker", "Bloquea por notificación, consulta su estado, entrega y registra cada intento.")
    Component(senders, "Adaptadores de canal", "Nodemailer / fetch", "Envía EMAIL por Gmail SMTP y SMS mediante la API REST de Twilio.")
}

Rel(emisores, http, "HTTPS / REST / JSON")
Rel(http, apiServices, "Ejecuta casos de uso")
Rel(apiServices, apiPersistence, "Lee o persiste")
Rel(apiPersistence, db, "SQL")

Rel(publisher, db, "FOR UPDATE SKIP LOCKED; marca publicado o reprograma", "SQL")
Rel(publisher, queueModule, "Crea job outbox-{id}")
Rel(queueModule, redis, "Almacena jobs BullMQ", "RESP")
Rel(redis, processor, "Entrega jobs disponibles", "RESP")
Rel(processor, db, "Advisory lock; lee estado y registra intentos", "SQL")
Rel(processor, senders, "Entrega contenido renderizado")
Rel(senders, gmail, "EMAIL", "SMTP")
Rel(senders, sms, "SMS", "HTTPS / REST")

SHOW_LEGEND()
@enduml
