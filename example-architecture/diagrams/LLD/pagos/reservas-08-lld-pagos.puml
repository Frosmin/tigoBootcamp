@startuml reservas-08-lld-pagos
' ============================================================
' LLD - Diagrama de Secuencia (Bajo Nivel)
' Backend: Orquestador de Pagos
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequence {
    ArrowColor #1168BD
    ArrowFontColor #333333
    LifeLineBorderColor #1168BD
    LifeLineBackgroundColor #D6E4F0
    ParticipantBorderColor #003865
    ParticipantBackgroundColor #003865
    ParticipantFontColor #FFFFFF
    ActorBorderColor #003865
    ActorBackgroundColor #003865
    BoxBorderColor #1168BD
    BoxFontColor #003865
}
skinparam noteBackgroundColor #FFF3CD
skinparam noteBorderColor #E0A800

title LLD - Orquestador de Pagos (Node.js / ultimate-express)

actor "Viajero" as user
participant "Router de\nPagos" as router

box "Orquestador de Pagos" #EAF2FB
    participant "Servicio de\nPagos" as svc
    participant "Repositorios\n(pg)" as repo
    participant "Conector\nPagos" as conn
    participant "Publicador\nde Eventos" as pub
end box

database "PostgreSQL" as db
participant "Pasarela\nde Pagos" as gw
participant "Bus de Eventos" as bus

autonumber "<b>[00]"

== A. Cobro ==
user -> router : POST /bookings/{id}/pay (medio, idempotencyKey)
activate router
router -> svc : procesarPago(reservaId, monto, idempotencyKey)
activate svc

svc -> repo : buscarPago(idempotencyKey)
activate repo
repo -> db : SELECT * FROM pagos WHERE idem_key=?
db --> repo : pago | null
repo --> svc : pago | null
deactivate repo

alt pago ya procesado (idempotencia)
    svc --> router : resultado previo (mismo response)
    router --> user : 200 OK (idempotente)
else primer intento
    svc -> repo : insert pago (estado=PENDIENTE)
    activate repo
    repo -> db : INSERT INTO pagos ...
    repo --> svc : pagoId
    deactivate repo

    svc -> conn : cobrar(monto, medio)
    activate conn
    loop reintentos (max 3, backoff)
        conn -> gw : POST /charges
        gw --> conn : aprobado | rechazado | timeout
    end
    conn --> svc : resultado del cobro
    deactivate conn

    alt cobro APROBADO
        svc -> repo : update pago (estado=APROBADO, txId)
        activate repo
        repo -> db : UPDATE pagos SET estado='APROBADO'
        deactivate repo
        svc -> pub : PagoProcesado(reservaId, APROBADO)
        pub -> bus : publish PagoProcesado
        svc --> router : pago aprobado
        router --> user : 200 OK (pago aprobado)
    else cobro RECHAZADO
        svc -> repo : update pago (estado=RECHAZADO, motivo)
        activate repo
        repo -> db : UPDATE pagos SET estado='RECHAZADO'
        deactivate repo
        svc -> pub : PagoProcesado(reservaId, RECHAZADO)
        pub -> bus : publish PagoProcesado
        svc --> router : pago rechazado
        router --> user : 402 Payment Required
    end
end
deactivate svc
deactivate router

== B. Reembolso (cancelacion) ==
opt reserva cancelada tras pago aprobado
    bus -> svc : ReservaCancelada(reservaId)
    activate svc
    svc -> conn : reembolsar(pagoId, monto)
    activate conn
    conn -> gw : POST /refunds
    gw --> conn : reembolso ok
    deactivate conn
    svc -> repo : update pago (estado=REEMBOLSADO)
    activate repo
    repo -> db : UPDATE pagos SET estado='REEMBOLSADO'
    deactivate repo
    svc -> pub : PagoReembolsado(reservaId)
    pub -> bus : publish PagoReembolsado
    deactivate svc
end

note over svc, conn
  Idempotencia por idempotencyKey y reintentos con backoff
  garantizan que un mismo cobro no se duplique.
end note

@enduml
