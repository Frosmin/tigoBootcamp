@startuml reservas-07-lld-reservas
' ============================================================
' LLD - Diagrama de Secuencia (Bajo Nivel)
' Backend: Servicio de Reservas
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequence {
    ArrowColor #1168BD
    ArrowFontColor #333333
    LifeLineBorderColor #1168BD
    LifeLineBackgroundColor #D6E4F0
    ParticipantBorderColor #003865
    ParticipantBackgroundColor #003865
    ParticipantFontColor #FFFFFF
    ActorBorderColor #003865
    ActorBackgroundColor #003865
    BoxBorderColor #1168BD
    BoxFontColor #003865
}
skinparam noteBackgroundColor #FFF3CD
skinparam noteBorderColor #E0A800

title LLD - Servicio de Reservas (Node.js / ultimate-express)

actor "Viajero" as user
participant "Router de\nReservas" as router

box "Servicio de Reservas" #EAF2FB
    participant "Servicio de\nReservas" as svc
    participant "Conector\nCache" as cCache
    participant "Repositorios\n(pg)" as repo
    participant "Publicador\nde Eventos" as pub
end box

participant "Cache\n(Redis)" as redis
database "PostgreSQL" as db
participant "Bus de Eventos" as bus
participant "GDS / Hoteles" as ext

autonumber "<b>[00]"

== A. Creacion de reserva (bloqueo temporal) ==
user -> router : POST /bookings (oferta, pasajeros)
activate router
router -> svc : crearReserva(oferta, pasajeros)
activate svc

svc -> ext : verifica disponibilidad
ext --> svc : disponible? si/no

alt sin disponibilidad
    svc --> router : 409 Conflict (oferta expirada)
    router --> user : 409 Conflict
else disponible
    svc -> cCache : crearHold(oferta, TTL)
    activate cCache
    cCache -> redis : SETEX hold:{id} TTL
    deactivate cCache

    svc -> repo : insert reserva (estado=PENDIENTE)
    activate repo
    repo -> db : INSERT INTO reservas ...
    db --> repo : reservaId
    repo --> svc : reservaId
    deactivate repo

    svc -> pub : ReservaCreada(reservaId)
    pub -> bus : publish ReservaCreada
    svc --> router : reservaId + hold
    router --> user : 201 Created (PENDIENTE de pago)
end
deactivate svc
deactivate router

== B. Confirmacion tras pago (evento asincrono) ==
bus -> svc : PagoProcesado(reservaId, estado)
activate svc
alt pago APROBADO
    svc -> ext : confirma reserva definitiva
    ext --> svc : localizador / voucher
    svc -> repo : update estado=CONFIRMADA + localizador
    activate repo
    repo -> db : UPDATE reservas SET estado='CONFIRMADA'
    deactivate repo
    svc -> cCache : libera hold
    svc -> pub : ReservaConfirmada(reservaId)
    pub -> bus : publish ReservaConfirmada
else pago RECHAZADO
    svc -> repo : update estado=CANCELADA
    activate repo
    repo -> db : UPDATE reservas SET estado='CANCELADA'
    deactivate repo
    svc -> cCache : libera hold
    svc -> pub : ReservaCancelada(reservaId)
    pub -> bus : publish ReservaCancelada
end
deactivate svc

== C. Expiracion del hold (sin pago a tiempo) ==
note over redis, svc
  Si el hold (TTL en Redis) expira sin pago, un job
  marca la reserva como EXPIRADA y libera el inventario.
end note

@enduml
