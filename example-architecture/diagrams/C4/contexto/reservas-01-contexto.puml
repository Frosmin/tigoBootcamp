@startuml reservas-01-contexto
' ============================================================
' C4 - Nivel 1: Diagrama de Contexto
' Sistema: Reservas de Vuelos y Hoteles (Backend / API)
' ============================================================
' Usa las librerias C4 locales (binaries/) en lugar de descargarlas de internet
!define RELATIVE_INCLUDE "."
!include ../../../binaries/C4_Context.puml

title Diagrama de Contexto (C1) - Sistema de Reservas de Vuelos y Hoteles

Person(viajero, "Viajero", "Busca disponibilidad, reserva vuelos/hoteles y gestiona sus reservas.")
Person(agente, "Agente de Soporte", "Consulta, modifica o cancela reservas a nombre del cliente.")

System(reservas, "Sistema de Reservas", "Backend API que orquesta búsqueda, disponibilidad, reservas y pagos de vuelos y hoteles.")

System_Ext(idp, "Proveedor de Identidad", "Autenticación y autorización (OAuth2 / OIDC).")
System_Ext(gds, "GDS de Vuelos", "Inventario y tarifas de aerolíneas (Amadeus / Sabre).")
System_Ext(hoteles, "Proveedor de Hoteles", "Channel manager / API de inventario y tarifas hoteleras.")
System_Ext(pagos, "Pasarela de Pagos", "Procesa cobros, reembolsos y tokeniza tarjetas.")
System_Ext(notif, "Servicio de Notificaciones", "Envío de correos y SMS de confirmación.")

Rel(viajero, reservas, "Busca y reserva vuelos/hoteles", "HTTPS/JSON")
Rel(agente, reservas, "Gestiona reservas de clientes", "HTTPS/JSON")

Rel(reservas, idp, "Valida tokens / autentica", "OIDC")
Rel(reservas, gds, "Consulta disponibilidad y confirma vuelos", "HTTPS/SOAP-REST")
Rel(reservas, hoteles, "Consulta disponibilidad y confirma hoteles", "HTTPS/JSON")
Rel(reservas, pagos, "Cobra y reembolsa", "HTTPS/JSON")
Rel(reservas, notif, "Solicita envío de confirmaciones", "HTTPS / eventos")

SHOW_LEGEND()
@enduml
