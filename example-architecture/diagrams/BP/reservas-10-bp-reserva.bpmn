<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_reservas"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Sistema de Reservas de Vuelos y Hoteles" processRef="Process_Reserva" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Reserva" isExecutable="false">

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Viajero" name="Viajero">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Ingresar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Revisar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Oferta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Abandono</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Seleccionar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Pagar</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Busqueda" name="Servicio de Busqueda">
        <bpmn:flowNodeRef>Task_Consultar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Normalizar</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Reservas" name="Servicio de Reservas">
        <bpmn:flowNodeRef>Task_Verificar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Disp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Expirada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CrearReserva</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Confirmar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Cancelar</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Pagos" name="Orquestador de Pagos">
        <bpmn:flowNodeRef>Task_Registrar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Procesar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Pago</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Notif" name="Notificaciones">
        <bpmn:flowNodeRef>Task_EnviarComprobante</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Confirmada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotificarRechazo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Rechazado</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_1" name="Inicio">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Ingresar" name="Ingresar criterios de busqueda">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Consultar" name="Consultar disponibilidad y tarifas">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Normalizar" name="Normalizar y ordenar ofertas">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Revisar" name="Revisar ofertas">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Oferta" name="Oferta adecuada?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Abandono" name="Busqueda abandonada">
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Seleccionar" name="Seleccionar oferta y pasajeros">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Verificar" name="Verificar disponibilidad">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Disp" name="Hay disponibilidad?">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Expirada" name="Oferta no disponible">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_CrearReserva" name="Crear reserva con hold (PENDIENTE)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Pagar" name="Realizar pago">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Registrar" name="Registrar intento de pago (idempotente)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Procesar" name="Procesar cobro (con reintentos)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Pago" name="Pago aprobado?">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Confirmar" name="Confirmar reserva (CONFIRMADA)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EnviarComprobante" name="Enviar comprobante">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Confirmada" name="Reserva confirmada">
      <bpmn:incoming>Flow_18</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Cancelar" name="Cancelar reserva y liberar hold">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_NotificarRechazo" name="Notificar pago rechazado">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Rechazado" name="Pago rechazado">
      <bpmn:incoming>Flow_21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Ingresar" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Ingresar" targetRef="Task_Consultar" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Consultar" targetRef="Task_Normalizar" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Normalizar" targetRef="Task_Revisar" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_Revisar" targetRef="Gateway_Oferta" />
    <bpmn:sequenceFlow id="Flow_6" name="no" sourceRef="Gateway_Oferta" targetRef="End_Abandono" />
    <bpmn:sequenceFlow id="Flow_7" name="si" sourceRef="Gateway_Oferta" targetRef="Task_Seleccionar" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Seleccionar" targetRef="Task_Verificar" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Verificar" targetRef="Gateway_Disp" />
    <bpmn:sequenceFlow id="Flow_10" name="no" sourceRef="Gateway_Disp" targetRef="End_Expirada" />
    <bpmn:sequenceFlow id="Flow_11" name="si" sourceRef="Gateway_Disp" targetRef="Task_CrearReserva" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_CrearReserva" targetRef="Task_Pagar" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_Pagar" targetRef="Task_Registrar" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_Registrar" targetRef="Task_Procesar" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_Procesar" targetRef="Gateway_Pago" />
    <bpmn:sequenceFlow id="Flow_16" name="si" sourceRef="Gateway_Pago" targetRef="Task_Confirmar" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_Confirmar" targetRef="Task_EnviarComprobante" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_EnviarComprobante" targetRef="End_Confirmada" />
    <bpmn:sequenceFlow id="Flow_19" name="no" sourceRef="Gateway_Pago" targetRef="Task_Cancelar" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Task_Cancelar" targetRef="Task_NotificarRechazo" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Task_NotificarRechazo" targetRef="End_Rechazado" />
  </bpmn:process>

