@startuml reservas-05-hld-secuencia
' ============================================================
' HLD - Diagrama de Secuencia (Alto Nivel)
' Interaccion entre los 3 backends: Busqueda, Reservas y Pagos
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam sequence {
    ArrowColor #1168BD
    ArrowFontColor #333333
    LifeLineBorderColor #1168BD
    LifeLineBackgroundColor #D6E4F0
    ParticipantBorderColor #003865
    ParticipantBackgroundColor #003865
    ParticipantFontColor #FFFFFF
    ActorBorderColor #003865
    ActorBackgroundColor #003865
    BoxBorderColor #1168BD
    BoxFontColor #003865
}
skinparam noteBackgroundColor #FFF3CD
skinparam noteBorderColor #E0A800

title HLD - Secuencia de reserva vuelo/hotel (Busqueda -> Reservas -> Pagos)

actor "Viajero" as user
participant "API REST" as api

box "Backends" #EAF2FB
    participant "Servicio de\nBusqueda" as busqueda
    participant "Servicio de\nReservas" as reserva
    participant "Orquestador\nde Pagos" as pago
end box

participant "Bus de Eventos" as bus
participant "Sistemas Externos\n(GDS / Hoteles / Pasarela)" as ext
participant "Notificaciones" as notif

autonumber "<b>[00]"

== 1. Busqueda de disponibilidad ==
user -> api : POST /search (origen, destino, fechas)
activate api
api -> busqueda : buscar(criterios)
activate busqueda
busqueda -> ext : consulta tarifas vuelos/hoteles
busqueda --> api : resultados normalizados
deactivate busqueda
api --> user : ofertas disponibles
deactivate api

== 2. Creacion de reserva (bloqueo temporal) ==
user -> api : POST /bookings (oferta seleccionada)
activate api
api -> reserva : crearReserva(oferta, pasajeros)
activate reserva
reserva -> ext : verifica disponibilidad
reserva --> api : reservaId + hold (estado PENDIENTE)
deactivate reserva
api --> user : reserva creada (a la espera de pago)
deactivate api

== 3. Pago ==
user -> api : POST /bookings/{id}/pay (medio de pago)
activate api
api -> pago : procesarPago(reservaId, monto)
activate pago
pago -> ext : cobra en pasarela
pago -> bus : publica PagoProcesado
pago --> api : pago aprobado
deactivate pago

== 4. Confirmacion (orquestacion entre backends) ==
bus -> reserva : PagoProcesado
activate reserva
reserva -> ext : confirma reserva definitiva
reserva -> bus : publica ReservaConfirmada
reserva --> api : reserva CONFIRMADA
deactivate reserva
api --> user : confirmacion (comprobante)
deactivate api

== 5. Notificacion ==
bus -> notif : ReservaConfirmada
notif -> user : envia comprobante (email / SMS)

note over busqueda, pago
  HLD: se muestran solo los mensajes entre backends
  y sistemas externos. El detalle interno de cada
  backend esta en los diagramas LLD.
end note

@enduml
